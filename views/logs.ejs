<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="content-card p-4 mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
          <div>
            <div class="section-title">Daily Logs</div>
            <div class="mini-note">Filter product, eload, and GCash activity by date. Changing the date updates every section below.</div>
          </div>
          <div class="d-flex flex-wrap align-items-end gap-3">
            <div>
              <label class="form-label mb-1" for="logsDatePicker">Log Date</label>
              <input class="form-control" id="logsDatePicker" type="date" value="<%= selectedDate %>">
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title">Product Logs</div>
                <div class="mini-note">All non-load item transactions for the selected date.</div>
              </div>
              <div class="badge rounded-pill text-bg-light border px-3 py-2" id="productLogsSummary"><%= logs.summary.productCount %> entries | <%= formatCurrency(logs.summary.productTotal) %></div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Log ID</th>
                    <th>Transaction</th>
                    <th class="text-end">Total Amount</th>
                    <th>Employee</th>
                    <th>Time Stamp</th>
                    <th class="text-end">Items</th>
                  </tr>
                </thead>
                <tbody id="productLogsBody">
                  <% if (logs.productLogs.length) { %>
                    <% logs.productLogs.forEach((entry) => { %>
                      <tr>
                        <td class="fw-semibold"><%= entry.logId %></td>
                        <td class="fw-semibold"><%= entry.transactionCode %></td>
                        <td class="text-end"><%= formatCurrency(entry.totalAmount) %></td>
                        <td><%= entry.employee || "-" %></td>
                        <td><%= formatDateTime(entry.timeStamp) %></td>
                        <td class="text-end">
                          <button
                            class="btn btn-sm btn-outline-secondary rounded-circle product-log-popover"
                            type="button"
                            data-bs-toggle="popover"
                            data-bs-trigger="focus"
                            data-bs-placement="left"
                            data-log-id="<%= entry.logId %>"
                            data-log-items='<%- JSON.stringify(entry.items) %>'
                            aria-label="Show purchased products"
                          >
                            <i class="bi bi-list-ul"></i>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="6" class="text-center py-4 mini-note">No product logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title">Eload Logs</div>
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-end" id="eloadLogsSummary">
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold"><%= logs.summary.eloadCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.eloadTotal) %></div>
                </div>
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold text-success">Completed</div>
                  <div class="fw-semibold"><%= logs.summary.eloadCompletedCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.eloadCompletedTotal) %></div>
                </div>
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold text-warning">Failed</div>
                  <div class="fw-semibold"><%= logs.summary.eloadFailedCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.eloadFailedTotal) %></div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Request</th>
                    <th>Number</th>
                    <th>Network</th>
                    <th>Load Item</th>
                    <th>Requested</th>
                    <th>Completed</th>
                    <th>Status</th>
                    <th class="text-end">Amount</th>
                  </tr>
                </thead>
                <tbody id="eloadLogsBody">
                  <% if (logs.eloadLogs.length) { %>
                    <% logs.eloadLogs.forEach((entry) => { %>
                      <tr>
                        <td class="fw-semibold"><%= entry.requestCode %></td>
                        <td><%= entry.number || "-" %></td>
                        <td><%= entry.network || "-" %></td>
                        <td><%= entry.loadValue || "-" %></td>
                        <td><%= entry.requestedBy || "-" %><div class="mini-note"><%= formatDateTime(entry.requestedAt) %></div></td>
                        <td><%= entry.completedBy || "-" %><div class="mini-note"><%= formatDateTime(entry.completedAt) %></div></td>
                        <td><span class="badge <%= entry.status === "Completed" ? "text-bg-success" : "text-bg-warning" %>"><%= entry.status %></span></td>
                        <td class="text-end"><%= formatCurrency(entry.amount) %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="8" class="text-center py-4 mini-note">No eload logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title">GCash Logs</div>
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-end" id="gcashLogsSummary">
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold"><%= logs.summary.gcashCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.gcashTotal) %></div>
                </div>
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold">Completed</div>
                  <div class="fw-semibold text-success"><%= logs.summary.gcashCompletedCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.gcashCompletedTotal) %></div>
                </div>
                <div class="content-card border p-3 text-start">
                  <div class="fw-semibold">Failed</div>
                  <div class="fw-semibold text-warning"><%= logs.summary.gcashFailedCount %> entries</div>
                  <div class="mini-note"><%= formatCurrency(logs.summary.gcashFailedTotal) %></div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Request</th>
                    <th>Number</th>
                    <th>Reference No.</th>
                    <th>Requested</th>
                    <th>Completed</th>
                    <th>Cash IN/OUT</th>
                    <th>Status</th>
                    <th class="text-end">Paid</th>
                  </tr>
                </thead>
                <tbody id="gcashLogsBody">
                  <% if (logs.gcashLogs.length) { %>
                    <% logs.gcashLogs.forEach((entry) => { %>
                      <tr>
                        <td class="fw-semibold"><%= entry.requestCode %></td>
                        <td><%= entry.number || "-" %></td>
                        <td><%= entry.referenceNo || "-" %></td>
                        <td><%= entry.requestedBy || "-" %><div class="mini-note"><%= formatDateTime(entry.requestedAt) %></div></td>
                        <td><%= entry.completedBy || "-" %><div class="mini-note"><%= formatDateTime(entry.completedAt) %></div></td>
                        <td><%= entry.requestKind || "Cash In" %></td>
                        <td><span class="badge <%= entry.status === "Completed" ? "text-bg-success" : "text-bg-warning" %>"><%= entry.status %></span></td>
                        <td class="text-end"><%= formatCurrency(entry.totalAmount) %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="8" class="text-center py-4 mini-note">No GCash logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const logsDatePicker = document.getElementById("logsDatePicker");
  const productLogsBody = document.getElementById("productLogsBody");
  const eloadLogsBody = document.getElementById("eloadLogsBody");
  const gcashLogsBody = document.getElementById("gcashLogsBody");
  const productLogsSummary = document.getElementById("productLogsSummary");
  const eloadLogsSummary = document.getElementById("eloadLogsSummary");
  const gcashLogsSummary = document.getElementById("gcashLogsSummary");
  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  let logsFetchController;

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function formatDateTimeClient(value) {
    if (!value) return "-";
    return new Date(`${String(value).replace(" ", "T")}Z`).toLocaleString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
      hour: "numeric",
      minute: "2-digit",
      timeZone: "Asia/Manila"
    });
  }

  function renderRows(body, rows, emptyMessage, columns, formatter) {
    if (!rows.length) {
      body.innerHTML = `<tr><td colspan="${columns}" class="text-center py-4 mini-note">${emptyMessage}</td></tr>`;
      return;
    }
    body.innerHTML = formatter(rows);
  }

  function renderProductPopoverContent(items) {
    if (!items?.length) {
      return '<div class="mini-note">No purchased products recorded for this log.</div>';
    }

    return `
      <div class="fw-semibold mb-2">Purchased Products</div>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Product</th>
              <th class="text-end">Qty</th>
              <th class="text-end">Price</th>
              <th class="text-end">Amount</th>
            </tr>
          </thead>
          <tbody>
            ${items.map((item) => `
              <tr>
                <td>${escapeHtml(item.itemName)}</td>
                <td class="text-end">${item.quantity}</td>
                <td class="text-end">${peso.format(item.sellingPrice)}</td>
                <td class="text-end">${peso.format(item.amount)}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      </div>
    `;
  }

  function bindProductLogPopovers() {
    if (typeof bootstrap === "undefined") return;

    document.querySelectorAll(".product-log-popover").forEach((button) => {
      const items = JSON.parse(button.dataset.logItems || "[]");
      bootstrap.Popover.getOrCreateInstance(button, {
        html: true,
        sanitize: false,
        customClass: "product-log-popover-card",
        content: renderProductPopoverContent(items)
      });
    });
  }

  async function loadLogs(date) {
    logsFetchController?.abort();
    logsFetchController = new AbortController();
    try {
      const response = await fetch(`/api/logs?date=${encodeURIComponent(date)}`, {
        headers: { Accept: "application/json" },
        signal: logsFetchController.signal
      });
      if (!response.ok) throw new Error("Failed to load logs.");
      const payload = await response.json();

      productLogsSummary.textContent = `${payload.summary.productCount} entries | ${peso.format(payload.summary.productTotal)}`;
      eloadLogsSummary.innerHTML = `
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Total</div>
          <div class="fw-semibold">${payload.summary.eloadCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.eloadTotal)}</div>
        </div>
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Completed</div>
          <div class="fw-semibold text-success">${payload.summary.eloadCompletedCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.eloadCompletedTotal)}</div>
        </div>
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Failed</div>
          <div class="fw-semibold text-warning">${payload.summary.eloadFailedCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.eloadFailedTotal)}</div>
        </div>
      `;
      gcashLogsSummary.innerHTML = `
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Total</div>
          <div class="fw-semibold">${payload.summary.gcashCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.gcashTotal)}</div>
        </div>
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Completed</div>
          <div class="fw-semibold text-success">${payload.summary.gcashCompletedCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.gcashCompletedTotal)}</div>
        </div>
        <div class="content-card border p-3 text-start">
          <div class="mini-note">Failed</div>
          <div class="fw-semibold text-warning">${payload.summary.gcashFailedCount} entries</div>
          <div class="mini-note">${peso.format(payload.summary.gcashFailedTotal)}</div>
        </div>
      `;

      renderRows(productLogsBody, payload.productLogs, "No product logs for this date.", 6, (rows) => rows.map((entry) => `
        <tr>
          <td class="fw-semibold">${entry.logId}</td>
          <td class="fw-semibold">${escapeHtml(entry.transactionCode)}</td>
          <td class="text-end">${peso.format(entry.totalAmount)}</td>
          <td>${escapeHtml(entry.employee || "-")}</td>
          <td>${escapeHtml(formatDateTimeClient(entry.timeStamp))}</td>
          <td class="text-end">
            <button
              class="btn btn-sm btn-outline-secondary rounded-circle product-log-popover"
              type="button"
              data-bs-toggle="popover"
              data-bs-trigger="focus"
              data-bs-placement="left"
              data-log-id="${entry.logId}"
              data-log-items='${escapeHtml(JSON.stringify(entry.items || []))}'
              aria-label="Show purchased products"
            >
              <i class="bi bi-list-ul"></i>
            </button>
          </td>
        </tr>
      `).join(""));
      bindProductLogPopovers();

      renderRows(eloadLogsBody, payload.eloadLogs, "No eload logs for this date.", 8, (rows) => rows.map((entry) => `
        <tr>
          <td class="fw-semibold">${escapeHtml(entry.requestCode)}</td>
          <td>${escapeHtml(entry.number || "-")}</td>
          <td>${escapeHtml(entry.network || "-")}</td>
          <td>${escapeHtml(entry.loadValue || "-")}</td>
          <td>${escapeHtml(entry.requestedBy || "-")}<div class="mini-note">${escapeHtml(formatDateTimeClient(entry.requestedAt))}</div></td>
          <td>${escapeHtml(entry.completedBy || "-")}<div class="mini-note">${escapeHtml(formatDateTimeClient(entry.completedAt))}</div></td>
          <td><span class="badge ${entry.status === "Completed" ? "text-bg-success" : "text-bg-warning"}">${escapeHtml(entry.status || "Pending")}</span></td>
          <td class="text-end">${peso.format(entry.amount)}</td>
        </tr>
      `).join(""));

      renderRows(gcashLogsBody, payload.gcashLogs, "No GCash logs for this date.", 8, (rows) => rows.map((entry) => `
        <tr>
          <td class="fw-semibold">${escapeHtml(entry.requestCode)}</td>
          <td>${escapeHtml(entry.number || "-")}</td>
          <td>${escapeHtml(entry.referenceNo || "-")}</td>
          <td>${escapeHtml(entry.requestedBy || "-")}<div class="mini-note">${escapeHtml(formatDateTimeClient(entry.requestedAt))}</div></td>
          <td>${escapeHtml(entry.completedBy || "-")}<div class="mini-note">${escapeHtml(formatDateTimeClient(entry.completedAt))}</div></td>
          <td>${escapeHtml(entry.requestKind || "Cash In")}</td>
          <td><span class="badge ${entry.status === "Completed" ? "text-bg-success" : "text-bg-warning"}">${escapeHtml(entry.status || "Pending")}</span></td>
          <td class="text-end">${peso.format(entry.totalAmount)}</td>
        </tr>
      `).join(""));

      const url = new URL(window.location.href);
      url.searchParams.set("date", payload.selectedDate);
      window.history.replaceState({}, "", url);
    } catch (error) {
      if (error.name !== "AbortError") console.error(error);
    }
  }

  logsDatePicker.addEventListener("change", () => {
    if (!logsDatePicker.value) return;
    loadLogs(logsDatePicker.value);
  });

  bindProductLogPopovers();
</script>
</body>
</html>
