<%- include("partials/head") %>
<main class="login-shell d-flex align-items-center justify-content-center p-4">
  <div class="w-100" style="max-width: 430px;">
    <div class="text-center mb-4">
      <div class="login-brand rounded-4 d-inline-flex align-items-center justify-content-center text-white mb-3">
        <i class="bi bi-shop fs-1"></i>
      </div>
      <h1 class="display-6 fw-bold mb-2">Sari-Sari Store</h1>
      <p class="text-secondary mb-0">Management System</p>
    </div>
    <div class="glass-card rounded-4 p-4 p-lg-5">
      <h2 class="h3 mb-2">Welcome Back</h2>
      <p class="text-secondary mb-4">Login to manage your store</p>
      <%- include("partials/flash") %>
      <form action="/login" method="post" class="vstack gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="form-label">Username</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person"></i></span>
            <input class="form-control" name="username" placeholder="Enter your username" required>
          </div>
        </div>
        <div>
          <label class="form-label">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input class="form-control" type="password" name="password" placeholder="Enter your password" required>
          </div>
        </div>
        <div class="d-flex justify-content-between align-items-center small">
          <span class="mini-note">Session expires automatically after inactivity.</span>
          <span class="text-success">Protected sign-in</span>
        </div>
        <button class="btn btn-success btn-lg">Sign In</button>
      </form>
      <div class="text-center mini-note mt-4">Demo credentials: <strong>admin</strong> / <strong>admin123</strong></div>
    </div>
    <p class="text-center mini-note mt-4 mb-0">&copy; 2026 Sari-Sari Store Management System</p>
  </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
