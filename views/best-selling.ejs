<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="row g-4 mb-4">
        <div class="col-md-4"><div class="metric-card top-item-card p-4 h-100"><div class="mini-note">Top Selling Item</div><% if (bestSelling.topItem) { %><div class="fs-4 fw-bold"><%= bestSelling.topItem.name %></div><div class="mini-note mt-2"><%= bestSelling.topItem.quantity_sold %> units sold</div><% } %></div></div>
        <div class="col-md-4"><div class="metric-card p-4 h-100"><div class="mini-note">Total Units Sold</div><div class="display-6 fw-bold"><%= bestSelling.totalUnitsSold %></div></div></div>
        <div class="col-md-4"><div class="metric-card p-4 h-100"><div class="mini-note">Total Revenue</div><div class="h2 fw-bold"><%= formatCurrency(bestSelling.totalRevenue) %></div></div></div>
      </div>
      <div class="row g-4 mb-4">
        <div class="col-xl-6"><div class="content-card p-4"><div class="section-title mb-3">Top Items by Quantity Sold</div><canvas id="quantityChart" height="220"></canvas></div></div>
        <div class="col-xl-6"><div class="content-card p-4"><div class="section-title mb-3">Top Items by Revenue</div><canvas id="revenueChart" height="220"></canvas></div></div>
      </div>
      <div class="content-card p-4">
        <div class="section-title mb-3">Best Selling Items Ranking</div>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead><tr><th>Rank</th><th>Item Name</th><th class="text-end">Quantity Sold</th><th class="text-end">Revenue</th><th class="text-end">Avg. Price</th></tr></thead>
            <tbody>
              <% bestSelling.items.forEach((item) => { %>
                <tr>
                  <td><span class="badge <%= item.rank === 1 ? 'badge-soft-warning' : item.rank === 2 ? 'badge-soft-info' : item.rank === 3 ? 'badge-soft-danger' : 'badge-soft-success' %>">#<%= item.rank %></span></td>
                  <td class="fw-semibold"><%= item.name %><% if (item.rank <= 3) { %><i class="bi bi-trophy-fill text-warning ms-2"></i><% } %></td>
                  <td class="text-end fw-semibold"><%= item.quantity_sold %></td>
                  <td class="text-end fw-semibold text-success"><%= formatCurrency(item.revenue) %></td>
                  <td class="text-end"><%= formatCurrency(item.averagePrice) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const items = <%- JSON.stringify(bestSelling.items.slice(0, 8)) %>;
  const labels = items.map(x => x.name.length > 20 ? `${x.name.slice(0, 20)}...` : x.name);
  const rootStyles = getComputedStyle(document.body);
  const axisColor = rootStyles.getPropertyValue("--text-muted").trim();
  const textColor = rootStyles.getPropertyValue("--text-strong").trim();
  const lineColor = rootStyles.getPropertyValue("--line-soft").trim();
  const emerald = rootStyles.getPropertyValue("--brand-emerald").trim();
  const teal = rootStyles.getPropertyValue("--brand-teal").trim();

  const sharedOptions = {
    indexAxis: "y",
    plugins: {
      legend: { display: false }
    },
    scales: {
      x: {
        ticks: { color: axisColor },
        grid: { color: lineColor }
      },
      y: {
        ticks: { color: textColor },
        grid: { display: false }
      }
    }
  };

  new Chart(document.getElementById("quantityChart"), {
    type: "bar",
    data: { labels, datasets: [{ data: items.map(x => x.quantity_sold), backgroundColor: emerald, borderRadius: 8 }] },
    options: sharedOptions
  });

  new Chart(document.getElementById("revenueChart"), {
    type: "bar",
    data: { labels, datasets: [{ data: items.map(x => x.revenue), backgroundColor: teal, borderRadius: 8 }] },
    options: sharedOptions
  });
</script>
</body>
</html>
