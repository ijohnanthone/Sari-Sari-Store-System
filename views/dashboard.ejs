<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-4"><a class="metric-card metric-card-link p-4 h-100 d-block text-reset text-decoration-none" href="/inventory"><div class="d-flex justify-content-between"><div><div class="mini-note">Total Products</div><div class="display-6 fw-bold" id="dashboardMetricTotalProducts"><%= metrics.totalProducts %></div><div class="mini-note">Current inventory records</div></div><div class="stat-icon blue"><i class="bi bi-box-seam fs-4"></i></div></div></a></div>
        <div class="col-md-6 col-xl-4"><a class="metric-card metric-card-link p-4 h-100 d-block text-reset text-decoration-none" href="/inventory?status=Low%20Stock"><div class="d-flex justify-content-between"><div><div class="mini-note">Low Stock Items</div><div class="display-6 fw-bold text-warning" id="dashboardMetricLowStock"><%= metrics.lowStockItems %></div><div class="mini-note">Need attention soon</div></div><div class="stat-icon yellow"><i class="bi bi-exclamation-triangle fs-4"></i></div></div></a></div>
        <div class="col-md-6 col-xl-4"><a class="metric-card metric-card-link p-4 h-100 d-block text-reset text-decoration-none" href="/inventory?status=Out%20of%20Stock"><div class="d-flex justify-content-between"><div><div class="mini-note">Out of Stock</div><div class="display-6 fw-bold text-danger" id="dashboardMetricOutOfStock"><%= metrics.outOfStockItems %></div><div class="mini-note">Reorder immediately</div></div><div class="stat-icon red"><i class="bi bi-x-octagon fs-4"></i></div></div></a></div>
        <div class="col-md-6 col-xl-4"><div class="metric-card p-4 h-100"><div class="d-flex justify-content-between"><div><div class="mini-note">Daily Sales</div><div class="h2 fw-bold" id="dashboardMetricDailySales"><%= formatCurrency(metrics.dailySales) %></div><div class="mini-note">As of <%= currentDateLabel %></div></div><div class="stat-icon green"><i class="bi bi-cash-stack fs-4"></i></div></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="metric-card p-4 h-100"><div class="d-flex justify-content-between"><div><div class="mini-note">Weekly Sales</div><div class="h2 fw-bold" id="dashboardMetricWeeklySales"><%= formatCurrency(metrics.weeklySales) %></div><div class="mini-note">Rolling 7-day performance</div></div><div class="stat-icon teal"><i class="bi bi-calendar-week fs-4"></i></div></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="metric-card p-4 h-100"><div class="d-flex justify-content-between"><div><div class="mini-note">Monthly Sales</div><div class="h2 fw-bold" id="dashboardMetricMonthlySales"><%= formatCurrency(metrics.monthlySales) %></div><div class="mini-note">Rolling 30-day revenue</div></div><div class="stat-icon cyan"><i class="bi bi-graph-up-arrow fs-4"></i></div></div></div></div>
      </div>
      <div class="row g-4 mb-4">
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title" id="dashboardChartTitle"><%= chartTitle %></div>
                <div class="mini-note">Daily trend for the current month, separated into GCash, Load, and Products.</div>
              </div>
            </div>
            <div class="h-100">
              <div class="mini-note mb-2">Trend View</div>
              <canvas id="salesTrendChart" height="110"></canvas>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-4 mb-4">
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3"><i class="bi bi-trophy text-warning me-2"></i>Best Selling Item This Month</div>
            <% if (bestSellingItem) { %>
              <div class="top-item-card rounded-4 p-4 d-flex gap-3 align-items-center" id="dashboardBestSellingCard">
                <div class="icon-chip"><i class="bi bi-award fs-4"></i></div>
                <div><div class="fw-bold fs-5"><%= bestSellingItem.name %></div><div class="mini-note"><%= bestSellingItem.quantity_sold %> units sold</div><div class="text-success fw-semibold"><%= formatCurrency(bestSellingItem.revenue) %> revenue</div></div>
              </div>
            <% } %>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3 text-warning"><i class="bi bi-exclamation-triangle me-2"></i>Low Stock Alert</div>
            <div class="vstack gap-3" id="dashboardLowStockList">
              <% lowStockItems.forEach((item) => { %>
                <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/inventory?status=<%= encodeURIComponent(item.status) %>&search=<%= encodeURIComponent(item.name) %>" style="background: rgba(245, 158, 11, 0.08);">
                  <div><div class="fw-semibold"><%= item.name %></div><div class="mini-note"><%= item.category %></div></div>
                  <div class="text-end"><div class="fw-bold <%= item.status === 'Out of Stock' ? 'text-danger' : 'text-warning' %>"><%= item.status %></div><div class="mini-note">Manual stock check</div></div>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-4">
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div class="section-title text-success mb-0"><i class="bi bi-phone me-2"></i>Pending Eload Requests</div>
              <a class="btn btn-sm btn-outline-success" href="/eload">Open Eload Queue</a>
            </div>
            <div class="vstack gap-3" id="dashboardPendingEloadList">
              <% if (!pendingEloadRequests.length) { %>
                <div class="mini-note text-center py-4">No pending eload requests right now.</div>
              <% } else { %>
                <% pendingEloadRequests.forEach((request) => { %>
                  <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/eload" style="background: rgba(34, 197, 94, 0.08);">
                    <div>
                      <div class="fw-semibold"><%= request.request_code %> | <%= request.mobile_number %></div>
                      <div class="mini-note"><%= request.network || "No network" %> | <%= request.load_value || request.load_type || "Pending load selection" %></div>
                    </div>
                    <div class="text-end">
                      <div class="fw-bold text-success"><%= formatCurrency(request.amount) %></div>
                      <div class="mini-note">Requested by <%= request.requested_by_name || "System" %></div>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div class="section-title text-primary mb-0"><i class="bi bi-wallet2 me-2"></i>Pending GCash Requests</div>
              <a class="btn btn-sm btn-outline-primary" href="/eload">Open GCash Queue</a>
            </div>
            <div class="vstack gap-3" id="dashboardPendingGcashList">
              <% if (!pendingGcashRequests.length) { %>
                <div class="mini-note text-center py-4">No pending GCash requests right now.</div>
              <% } else { %>
                <% pendingGcashRequests.forEach((request) => { %>
                  <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/eload" style="background: rgba(59, 130, 246, 0.08);">
                    <div>
                      <div class="fw-semibold"><%= request.request_code %> | <%= request.mobile_number %></div>
                      <div class="mini-note"><%= request.request_kind || "GCash request" %> | <%= request.reference_no || "Reference pending" %></div>
                    </div>
                    <div class="text-end">
                      <div class="fw-bold text-primary"><%= formatCurrency(request.amount) %></div>
                      <div class="mini-note">Requested by <%= request.requested_by_name || "System" %></div>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const chartTitleElement = document.getElementById("dashboardChartTitle");
  const dashboardMetricTotalProducts = document.getElementById("dashboardMetricTotalProducts");
  const dashboardMetricLowStock = document.getElementById("dashboardMetricLowStock");
  const dashboardMetricOutOfStock = document.getElementById("dashboardMetricOutOfStock");
  const dashboardMetricDailySales = document.getElementById("dashboardMetricDailySales");
  const dashboardMetricWeeklySales = document.getElementById("dashboardMetricWeeklySales");
  const dashboardMetricMonthlySales = document.getElementById("dashboardMetricMonthlySales");
  const dashboardBestSellingCard = document.getElementById("dashboardBestSellingCard");
  const dashboardLowStockList = document.getElementById("dashboardLowStockList");
  const dashboardPendingEloadList = document.getElementById("dashboardPendingEloadList");
  const dashboardPendingGcashList = document.getElementById("dashboardPendingGcashList");
  const rootStyles = getComputedStyle(document.body);
  const lineColor = rootStyles.getPropertyValue("--line-soft").trim();
  const textColor = rootStyles.getPropertyValue("--text-muted").trim();
  const gcashBlue = rootStyles.getPropertyValue("--brand-blue").trim() || "#3b82f6";
  const loadLightGreen = "#86efac";
  const productsOrange = "#f59e0b";

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  const sharedOptions = {
    responsive: true,
    plugins: {
      legend: {
        display: true,
        position: "top",
        labels: { color: textColor, usePointStyle: true, boxWidth: 10 }
      }
    },
    scales: {
      x: { ticks: { color: textColor }, grid: { color: lineColor } },
      y: { ticks: { color: textColor }, grid: { color: lineColor } }
    }
  };

  const salesTrendChart = new Chart(document.getElementById("salesTrendChart"), {
    type: "line",
    data: {
      labels: <%- JSON.stringify(chartLabels) %>,
      datasets: [
        { label: "GCash", data: <%- JSON.stringify(chartDatasets[0].values) %>, borderColor: gcashBlue, backgroundColor: gcashBlue, pointBackgroundColor: gcashBlue, fill: false, tension: 0.35 },
        { label: "Load", data: <%- JSON.stringify(chartDatasets[1].values) %>, borderColor: loadLightGreen, backgroundColor: loadLightGreen, pointBackgroundColor: loadLightGreen, fill: false, tension: 0.35 },
        { label: "Products", data: <%- JSON.stringify(chartDatasets[2].values) %>, borderColor: productsOrange, backgroundColor: productsOrange, pointBackgroundColor: productsOrange, fill: false, tension: 0.35 }
      ]
    },
    options: sharedOptions
  });

  async function loadDashboardOverview() {
    try {
      const response = await fetch("/api/dashboard/overview", { headers: { Accept: "application/json" } });
      if (!response.ok) throw new Error("Failed to load dashboard overview.");
      const payload = await response.json();
      dashboardMetricTotalProducts.textContent = String(payload.metrics.totalProducts);
      dashboardMetricLowStock.textContent = String(payload.metrics.lowStockItems);
      dashboardMetricOutOfStock.textContent = String(payload.metrics.outOfStockItems);
      dashboardMetricDailySales.textContent = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(payload.metrics.dailySales);
      dashboardMetricWeeklySales.textContent = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(payload.metrics.weeklySales);
      dashboardMetricMonthlySales.textContent = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(payload.metrics.monthlySales);

      if (payload.bestSellingItem && dashboardBestSellingCard) {
        dashboardBestSellingCard.innerHTML = `
          <div class="icon-chip"><i class="bi bi-award fs-4"></i></div>
          <div><div class="fw-bold fs-5">${payload.bestSellingItem.name}</div><div class="mini-note">${payload.bestSellingItem.quantity_sold} units sold</div><div class="text-success fw-semibold">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(payload.bestSellingItem.revenue)} revenue</div></div>
        `;
      }

      if (dashboardLowStockList) {
        dashboardLowStockList.innerHTML = payload.lowStockItems.map((item) => `
          <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/inventory?status=${encodeURIComponent(item.status)}&search=${encodeURIComponent(item.name)}" style="background: rgba(245, 158, 11, 0.08);">
            <div><div class="fw-semibold">${item.name}</div><div class="mini-note">${item.category}</div></div>
            <div class="text-end"><div class="fw-bold ${item.status === "Out of Stock" ? "text-danger" : "text-warning"}">${item.status}</div><div class="mini-note">Manual stock check</div></div>
          </a>
        `).join("");
      }

      if (dashboardPendingEloadList) {
        dashboardPendingEloadList.innerHTML = payload.pendingEloadRequests.length
          ? payload.pendingEloadRequests.map((request) => `
            <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/eload" style="background: rgba(34, 197, 94, 0.08);">
              <div>
                <div class="fw-semibold">${escapeHtml(request.request_code)} | ${escapeHtml(request.mobile_number)}</div>
                <div class="mini-note">${escapeHtml(request.network || "No network")} | ${escapeHtml(request.load_value || request.load_type || "Pending load selection")}</div>
              </div>
              <div class="text-end">
                <div class="fw-bold text-success">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(request.amount || 0)}</div>
                <div class="mini-note">Requested by ${escapeHtml(request.requested_by_name || "System")}</div>
              </div>
            </a>
          `).join("")
          : `<div class="mini-note text-center py-4">No pending eload requests right now.</div>`;
      }

      if (dashboardPendingGcashList) {
        dashboardPendingGcashList.innerHTML = payload.pendingGcashRequests.length
          ? payload.pendingGcashRequests.map((request) => `
            <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-4 p-3 text-reset text-decoration-none" href="/eload" style="background: rgba(59, 130, 246, 0.08);">
              <div>
                <div class="fw-semibold">${escapeHtml(request.request_code)} | ${escapeHtml(request.mobile_number)}</div>
                <div class="mini-note">${escapeHtml(request.request_kind || "GCash request")} | ${escapeHtml(request.reference_no || "Reference pending")}</div>
              </div>
              <div class="text-end">
                <div class="fw-bold text-primary">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(request.amount || 0)}</div>
                <div class="mini-note">Requested by ${escapeHtml(request.requested_by_name || "System")}</div>
              </div>
            </a>
          `).join("")
          : `<div class="mini-note text-center py-4">No pending GCash requests right now.</div>`;
      }
    } catch (error) {
      console.error(error);
    }
  }

  async function refreshDashboardChart() {
    try {
      const response = await fetch("/api/dashboard/chart", { headers: { Accept: "application/json" } });
      if (!response.ok) throw new Error("Failed to load chart data.");
      const chart = await response.json();
      chartTitleElement.textContent = chart.title;
      salesTrendChart.data.labels = chart.labels;
      salesTrendChart.data.datasets[0].data = chart.datasets[0].values;
      salesTrendChart.data.datasets[1].data = chart.datasets[1].values;
      salesTrendChart.data.datasets[2].data = chart.datasets[2].values;
      salesTrendChart.update();
    } catch (error) {
      console.error(error);
    }
  }

  loadDashboardOverview();
  refreshDashboardChart();
</script>
</body>
</html>
