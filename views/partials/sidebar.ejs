<aside class="sidebar d-flex flex-column p-3 p-lg-4">
  <div class="d-flex align-items-center gap-3 mb-4">
    <div class="brand-chip"><i class="bi bi-shop fs-4"></i></div>
    <div>
      <h1 class="h5 mb-0"><%= store.store_name %></h1>
      <div class="mini-note">Management System</div>
    </div>
  </div>
  <nav class="nav nav-pills flex-column gap-2">
    <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/"><i class="bi bi-grid me-2"></i>Dashboard</a>
    <a class="nav-link <%= currentPath.startsWith('/inventory') ? 'active' : '' %>" href="/inventory"><i class="bi bi-box-seam me-2"></i>Inventory</a>
    <% if (user && user.role === "Admin") { %>
      <a class="nav-link <%= currentPath.startsWith('/sales') ? 'active' : '' %>" href="/sales"><i class="bi bi-cart3 me-2"></i>Sales</a>
      <a class="nav-link <%= currentPath.startsWith('/reports') ? 'active' : '' %>" href="/reports"><i class="bi bi-bar-chart-line me-2"></i>Reports</a>
      <a class="nav-link <%= currentPath.startsWith('/best-selling') ? 'active' : '' %>" href="/best-selling"><i class="bi bi-trophy me-2"></i>Best Selling</a>
      <a class="nav-link <%= currentPath.startsWith('/users') ? 'active' : '' %>" href="/users"><i class="bi bi-people me-2"></i>User Accounts</a>
    <% } %>
    <a class="nav-link <%= currentPath.startsWith('/settings') ? 'active' : '' %>" href="/settings"><i class="bi bi-gear me-2"></i>Settings</a>
  </nav>
  <div class="mt-auto pt-4">
    <div class="content-card p-3">
      <div class="mini-note">Version 1.0.0</div>
      <div class="mini-note">Based on the Figma sari-sari store concept</div>
    </div>
  </div>
</aside>
