<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="row g-4">
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
              <div>
                <div class="section-title">Digital Service Requests</div>
                <div class="mini-note">Any user or admin can create a pending Eload or GCash request, then complete it later with a full requester/completer audit trail.</div>
              </div>
              <span class="badge rounded-pill text-bg-light border px-3 py-2"><%= requests.filter((entry) => entry.status === "Pending").length %> pending</span>
            </div>

            <div class="eload-service-grid mb-4" id="eloadServiceGrid">
              <button type="button" class="eload-service-card is-selected" data-service="eload">
                <span class="fw-semibold fs-5">Eload Request</span>
                <span class="mini-note">Encode mobile number, network, and load option first, then complete the request later.</span>
              </button>
              <button type="button" class="eload-service-card" data-service="gcash">
                <span class="fw-semibold fs-5">GCash Request</span>
                <span class="mini-note">Create cash-in or cash-out requests, then complete them once the transaction reference is ready.</span>
              </button>
            </div>

            <div id="eloadFlowCard">
              <form id="eloadForm" class="row g-4" method="post" action="/eload/requests" autocomplete="off">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="serviceType" value="eload">
                <input type="hidden" name="network" id="eloadNetworkValue">
                <input type="hidden" name="loadValue" id="eloadLoadValue">
                <input type="hidden" name="amount" id="eloadAmountValue">

                <div class="col-12">
                  <label class="form-label" for="eloadMobileNumber">Mobile Number</label>
                  <input class="form-control form-control-lg" id="eloadMobileNumber" name="mobileNumber" inputmode="numeric" maxlength="13" placeholder="09XX XXX XXXX" required>
                  <div class="mini-note mt-2">Accepted format: 11-digit Philippine mobile number starting with `09`.</div>
                </div>

                <div class="col-12">
                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <label class="form-label mb-0">Choose Network</label>
                    <div class="mini-note" id="eloadSelectedNetworkText">No network selected yet</div>
                  </div>
                  <div class="eload-network-grid" id="eloadNetworkGrid"></div>
                </div>

                <div class="col-12">
                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <input class="btn-check" type="radio" name="loadType" id="eloadTypePromo" value="promo" checked>
                    <label class="btn btn-outline-secondary rounded-pill px-4" for="eloadTypePromo">Promo Load</label>

                    <input class="btn-check" type="radio" name="loadType" id="eloadTypeRegular" value="regular">
                    <label class="btn btn-outline-secondary rounded-pill px-4" for="eloadTypeRegular">Regular Load</label>

                    <input class="btn-check" type="radio" name="loadType" id="eloadTypeGcash" value="gcash">
                    <label class="btn btn-outline-secondary rounded-pill px-4" for="eloadTypeGcash">GCash Exclusive</label>
                  </div>

                  <div class="row g-4">
                    <div class="col-lg-7" id="eloadPromoSection">
                      <label class="form-label" for="eloadPromoSelect">Promo Option</label>
                      <select class="form-select" id="eloadPromoSelect"></select>
                      <div class="mini-note mt-2" id="eloadPromoHelp">Choose a network first to see available promos.</div>
                    </div>

                    <div class="col-lg-5 d-none" id="eloadRegularSection">
                      <label class="form-label" for="eloadRegularAmount">Regular Amount</label>
                      <div class="input-group">
                        <span class="input-group-text">PHP</span>
                        <input class="form-control" id="eloadRegularAmount" type="number" min="1" step="1" placeholder="50">
                      </div>
                      <div class="mini-note mt-2">Enter any whole-number load amount.</div>
                    </div>

                    <div class="col-lg-7 d-none" id="eloadGcashSection">
                      <label class="form-label" for="eloadGcashSelect">GCash Exclusive Option</label>
                      <select class="form-select" id="eloadGcashSelect">
                        <option value="GCash Exclusive 50">GCash Exclusive 50</option>
                        <option value="GCash Exclusive 99">GCash Exclusive 99</option>
                        <option value="GCash Exclusive 150">GCash Exclusive 150</option>
                        <option value="GCash Exclusive 299">GCash Exclusive 299</option>
                      </select>
                      <div class="mini-note mt-2">Special GCash-only offers for digital wallet load purchases.</div>
                    </div>
                  </div>
                </div>

                <div class="col-12">
                  <label class="form-label" for="eloadNotes">Request Notes</label>
                  <textarea class="form-control" id="eloadNotes" name="notes" rows="2" placeholder="Optional notes for the staff who will complete this request."></textarea>
                </div>

                <div class="col-12">
                  <div class="eload-preview p-4 rounded-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                      <div>
                        <div class="mini-note">Request Preview</div>
                        <div class="h4 mb-1" id="eloadPreviewTitle">Ready to create eload request</div>
                        <div class="mini-note" id="eloadPreviewSubtitle">Complete the fields to preview the selected load request.</div>
                      </div>
                      <div class="badge rounded-pill text-bg-success px-3 py-2" id="eloadPreviewMode">Promo</div>
                    </div>
                    <div class="row g-3 mt-1">
                      <div class="col-md-3">
                        <div class="mini-note">Number</div>
                        <div class="fw-semibold" id="eloadPreviewNumber">09XX XXX XXXX</div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note">Network</div>
                        <div class="fw-semibold" id="eloadPreviewNetwork">Select network</div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note">Selected Load</div>
                        <div class="fw-semibold" id="eloadPreviewValue">Choose an option</div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note">Amount</div>
                        <div class="fw-semibold" id="eloadPreviewAmount">PHP 0.00</div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="col-12">
                  <div id="eloadActionAlert"></div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-success px-4" type="submit">Create Eload Request</button>
                    <button class="btn btn-outline-success px-4" type="button" id="eloadAddToCartButton">Add to Cart</button>
                  </div>
                </div>
              </form>
            </div>

            <div id="gcashFlowCard" class="d-none">
              <div class="content-card border-0 shadow-none p-0">
                <div class="section-title mb-2">GCash Request</div>
                <div class="mini-note mb-4">Create the request first. When the payment or reference is ready, complete it from the pending queue below.</div>

                <form id="gcashForm" class="row g-4" method="post" action="/eload/requests" autocomplete="off">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="serviceType" value="gcash">

                  <div class="col-md-6">
                    <label class="form-label" for="gcashMobileNumber">GCash Number</label>
                    <input class="form-control form-control-lg" id="gcashMobileNumber" name="mobileNumber" inputmode="numeric" maxlength="13" placeholder="09XX XXX XXXX" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="gcashReferenceNumber">Reference Number</label>
                    <input class="form-control form-control-lg" id="gcashReferenceNumber" name="referenceNumber" placeholder="Optional when creating, required when completing">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="gcashCashFlow">Cash Flow</label>
                    <select class="form-select form-select-lg" id="gcashCashFlow" name="cashFlow">
                      <option value="Cash In">Cash In</option>
                      <option value="Cash Out">Cash Out</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="gcashAmount">Amount</label>
                    <div class="input-group input-group-lg">
                      <span class="input-group-text">PHP</span>
                      <input class="form-control" id="gcashAmount" name="amount" type="number" min="1" step="1" placeholder="100" required>
                    </div>
                  </div>
                  <div class="col-12">
                    <label class="form-label" for="gcashNotes">Request Notes</label>
                    <textarea class="form-control" id="gcashNotes" name="notes" rows="2" placeholder="Optional reminder or instruction for the completing staff."></textarea>
                  </div>

                  <div class="col-12">
                    <div class="eload-preview p-4 rounded-4">
                      <div class="mini-note">GCash Request Preview</div>
                      <div class="h4 mb-1" id="gcashPreviewTitle">Ready to create GCash request</div>
                      <div class="mini-note mb-3" id="gcashPreviewSubtitle">Complete the fields to preview the request details.</div>
                      <div class="row g-3">
                        <div class="col-md-3">
                          <div class="mini-note">Number</div>
                          <div class="fw-semibold" id="gcashPreviewNumber">09XX XXX XXXX</div>
                        </div>
                        <div class="col-md-3">
                          <div class="mini-note">Reference</div>
                          <div class="fw-semibold" id="gcashPreviewReference">Pending</div>
                        </div>
                        <div class="col-md-3">
                          <div class="mini-note">Flow</div>
                          <div class="fw-semibold" id="gcashPreviewFlow">Cash In</div>
                        </div>
                        <div class="col-md-3">
                          <div class="mini-note">Amount</div>
                          <div class="fw-semibold" id="gcashPreviewAmount">PHP 0.00</div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-12">
                    <button class="btn btn-success px-4" type="submit">Create GCash Request</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title">Pending Requests</div>
                <div class="mini-note">Open requests can be completed by any logged-in user or admin.</div>
              </div>
              <span class="badge rounded-pill text-bg-warning"><%= requests.filter((entry) => entry.status === "Pending").length %> open</span>
            </div>
            <div id="pendingRequestActionAlert" class="mb-3"></div>

            <% const pendingRequests = requests.filter((entry) => entry.status === "Pending"); %>
            <% if (!pendingRequests.length) { %>
              <div class="mini-note text-center py-4">No pending digital service requests right now.</div>
            <% } else { %>
              <div class="vstack gap-3">
                <% pendingRequests.forEach((entry) => { %>
                  <div class="border rounded-4 p-3 p-lg-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                      <div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                          <span class="fw-semibold"><%= entry.request_code %></span>
                          <span class="badge <%= entry.service_type === "gcash" ? "text-bg-primary" : "text-bg-success" %>"><%= entry.service_type === "gcash" ? "GCash" : "Eload" %></span>
                          <span class="badge text-bg-warning">Pending</span>
                        </div>
                        <div class="mini-note">
                          Requested by <strong><%= entry.requested_by_name %></strong> on <strong><%= formatDateTime(entry.requested_at) %></strong>
                        </div>
                        </div>
                        <div class="text-lg-end">
                          <div class="fw-semibold text-success"><%= formatCurrency(entry.amount) %></div>
                          <div class="d-inline-flex align-items-center gap-2">
                            <div class="mini-note mb-0"><%= entry.mobile_number %></div>
                            <button
                              class="btn btn-sm btn-outline-secondary pending-request-copy"
                              type="button"
                              data-copy-number="<%= entry.mobile_number %>"
                              aria-label="Copy mobile number"
                            >
                              <i class="bi bi-clipboard"></i>
                            </button>
                          </div>
                        </div>
                      </div>

                    <div class="row g-3 mb-3">
                      <div class="col-md-3">
                        <div class="mini-note">Request Type</div>
                        <div class="fw-semibold"><%= entry.service_type === "gcash" ? entry.request_kind : entry.load_type %></div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note"><%= entry.service_type === "gcash" ? "Reference" : "Network" %></div>
                        <div class="fw-semibold"><%= entry.service_type === "gcash" ? (entry.reference_no || "Pending") : entry.network %></div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note"><%= entry.service_type === "gcash" ? "Status" : "Load Value" %></div>
                        <div class="fw-semibold"><%= entry.service_type === "gcash" ? entry.status : entry.load_value %></div>
                      </div>
                      <div class="col-md-3">
                        <div class="mini-note">Notes</div>
                        <div class="fw-semibold"><%= entry.notes || "-" %></div>
                      </div>
                    </div>

                    <form method="post" action="/eload/requests/<%= entry.id %>/complete" class="row g-3 align-items-end">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <% if (entry.service_type === "gcash") { %>
                        <div class="col-lg-5">
                          <label class="form-label">Reference Number</label>
                          <input class="form-control" name="referenceNumber" value="<%= entry.reference_no %>" placeholder="Required to complete GCash" required>
                        </div>
                      <% } else { %>
                        <div class="col-lg-5">
                          <div class="mini-note">Completing this eload request will stamp who completed it and the exact date/time.</div>
                        </div>
                      <% } %>
                      <div class="col-lg-3">
                        <button class="btn btn-success w-100">Mark as Completed</button>
                      </div>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const networkPromos = {
    TM: ["EZ50", "ASTIG99", "ALLNET20", "EASYSURF50"],
    GLOBE: ["GO59", "GO+99", "GOUNLI129", "SURF4ALL99"],
    SMART: ["ALL DATA 50", "MAGICSARAP99", "POWER ALL 99", "GIGA VIDEO 99"],
    TNT: ["TNT PANALO 30", "SURFSAYA 50", "ALL DATA 99", "SAYA ALL 99"],
    SUN: ["CTC50", "TU200", "SURF50", "UNLI TXT 50"],
    DITO: ["DITO 10", "DITO 50", "LEVEL-UP 99", "UNLI 5G 149"]
  };

  const networkDescriptions = {
    TM: "Budget-friendly TM promos and all-net essentials.",
    GLOBE: "Popular Globe data, call, and combo offers.",
    SMART: "Smart data bundles and Magic Data-style options.",
    TNT: "TNT promo picks for calls, texts, and data.",
    SUN: "Classic Sun load combos for texts and calls.",
    DITO: "DITO data-focused packs and modern bundles."
  };

  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  const eloadServiceGrid = document.getElementById("eloadServiceGrid");
  const eloadFlowCard = document.getElementById("eloadFlowCard");
  const gcashFlowCard = document.getElementById("gcashFlowCard");
  const eloadMobileNumber = document.getElementById("eloadMobileNumber");
  const eloadNetworkGrid = document.getElementById("eloadNetworkGrid");
  const eloadSelectedNetworkText = document.getElementById("eloadSelectedNetworkText");
  const eloadPromoSelect = document.getElementById("eloadPromoSelect");
  const eloadPromoHelp = document.getElementById("eloadPromoHelp");
  const eloadPromoSection = document.getElementById("eloadPromoSection");
  const eloadRegularSection = document.getElementById("eloadRegularSection");
  const eloadGcashSection = document.getElementById("eloadGcashSection");
  const eloadRegularAmount = document.getElementById("eloadRegularAmount");
  const eloadGcashSelect = document.getElementById("eloadGcashSelect");
  const eloadNotes = document.getElementById("eloadNotes");
  const eloadPreviewTitle = document.getElementById("eloadPreviewTitle");
  const eloadPreviewSubtitle = document.getElementById("eloadPreviewSubtitle");
  const eloadPreviewMode = document.getElementById("eloadPreviewMode");
  const eloadPreviewNumber = document.getElementById("eloadPreviewNumber");
  const eloadPreviewNetwork = document.getElementById("eloadPreviewNetwork");
  const eloadPreviewValue = document.getElementById("eloadPreviewValue");
  const eloadPreviewAmount = document.getElementById("eloadPreviewAmount");
  const eloadNetworkValue = document.getElementById("eloadNetworkValue");
  const eloadLoadValue = document.getElementById("eloadLoadValue");
  const eloadAmountValue = document.getElementById("eloadAmountValue");
  const eloadActionAlert = document.getElementById("eloadActionAlert");
  const eloadAddToCartButton = document.getElementById("eloadAddToCartButton");
  const gcashMobileNumber = document.getElementById("gcashMobileNumber");
  const gcashReferenceNumber = document.getElementById("gcashReferenceNumber");
  const gcashCashFlow = document.getElementById("gcashCashFlow");
  const gcashAmount = document.getElementById("gcashAmount");
  const gcashPreviewTitle = document.getElementById("gcashPreviewTitle");
  const gcashPreviewSubtitle = document.getElementById("gcashPreviewSubtitle");
  const gcashPreviewNumber = document.getElementById("gcashPreviewNumber");
  const gcashPreviewReference = document.getElementById("gcashPreviewReference");
  const gcashPreviewFlow = document.getElementById("gcashPreviewFlow");
  const gcashPreviewAmount = document.getElementById("gcashPreviewAmount");
  const loadTypeInputs = Array.from(document.querySelectorAll("input[name='loadType']"));
  const pendingRequestActionAlert = document.getElementById("pendingRequestActionAlert");

  let selectedNetwork = "";
  let selectedService = "eload";
  const salesCartStorageKey = "sales-cart-state";
  const salesCartOpenStorageKey = "sales-cart-open-on-load";

  function onlyDigits(value) {
    return String(value || "").replace(/\D/g, "").slice(0, 11);
  }

  function formatPhilippineMobile(value) {
    const digits = onlyDigits(value);
    const first = digits.slice(0, 4);
    const second = digits.slice(4, 7);
    const third = digits.slice(7, 11);
    return [first, second, third].filter(Boolean).join(" ");
  }

  function getLoadType() {
    return loadTypeInputs.find((input) => input.checked)?.value || "promo";
  }

  function parseLastAmount(value) {
    const match = String(value || "").match(/(\d+(?:\.\d+)?)/g);
    if (!match || !match.length) return 0;
    return Number(match[match.length - 1]);
  }

  function showEloadActionAlert(type, message) {
    eloadActionAlert.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show mt-3 mb-0" role="alert">${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
  }

  function showPendingRequestActionAlert(type, message) {
    if (!pendingRequestActionAlert) return;
    pendingRequestActionAlert.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show mb-0" role="alert">${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
  }

  function getEloadDraft() {
    const digits = onlyDigits(eloadMobileNumber.value);
    const loadType = getLoadType();
    const selectedValue = loadType === "promo"
      ? (eloadPromoSelect.value || "")
      : loadType === "regular"
        ? (eloadRegularAmount.value ? `Regular ${eloadRegularAmount.value}` : "")
        : (eloadGcashSelect.value || "");
    const amount = loadType === "regular" ? Number(eloadRegularAmount.value || 0) : parseLastAmount(selectedValue);

    if (digits.length !== 11 || !digits.startsWith("09")) {
      throw new Error("Enter a valid 11-digit mobile number before adding to cart.");
    }
    if (!selectedNetwork) {
      throw new Error("Choose a network before adding to cart.");
    }
    if (!selectedValue) {
      throw new Error("Choose a load option before adding to cart.");
    }
    if (amount <= 0) {
      throw new Error("Enter a valid amount before adding to cart.");
    }

    return {
      id: `eload-${Date.now()}`,
      type: "eload",
      name: `${selectedNetwork} ${selectedValue}`,
      mobileNumber: formatPhilippineMobile(digits),
      network: selectedNetwork,
      loadType,
      loadValue: selectedValue,
      notes: eloadNotes.value.trim(),
      quantity: 1,
      price: amount
    };
  }

  function addEloadDraftToCart() {
    try {
      const draft = getEloadDraft();
      const raw = window.localStorage.getItem(salesCartStorageKey);
      const parsed = raw ? JSON.parse(raw) : [];
      const cart = Array.isArray(parsed) ? parsed : [];
      cart.push(draft);
      window.localStorage.setItem(salesCartStorageKey, JSON.stringify(cart));
      window.localStorage.setItem(salesCartOpenStorageKey, "true");
      window.location.href = "/sales?cart=open";
    } catch (error) {
      showEloadActionAlert("danger", error.message);
    }
  }

  function renderNetworks() {
    eloadNetworkGrid.innerHTML = Object.keys(networkPromos).map((network) => `
      <button type="button" class="eload-network-card ${selectedNetwork === network ? "is-selected" : ""}" data-network="${network}">
        <span class="fw-semibold">${network}</span>
        <span class="mini-note">${networkDescriptions[network]}</span>
      </button>
    `).join("");
  }

  function renderPromoOptions() {
    if (!selectedNetwork) {
      eloadPromoSelect.innerHTML = '<option value="">Choose a network first</option>';
      eloadPromoSelect.disabled = true;
      eloadPromoHelp.textContent = "Choose a network first to see available promos.";
      return;
    }

    const promos = networkPromos[selectedNetwork] || [];
    eloadPromoSelect.innerHTML = promos.map((promo) => `<option value="${promo}">${promo}</option>`).join("");
    eloadPromoSelect.disabled = false;
    eloadPromoHelp.textContent = `${selectedNetwork} promos are ready to choose.`;
  }

  function updateServiceCards() {
    eloadServiceGrid.querySelectorAll("[data-service]").forEach((button) => {
      button.classList.toggle("is-selected", button.dataset.service === selectedService);
    });
    eloadFlowCard.classList.toggle("d-none", selectedService !== "eload");
    gcashFlowCard.classList.toggle("d-none", selectedService !== "gcash");
  }

  function updateLoadSections() {
    const loadType = getLoadType();
    const isPromo = loadType === "promo";
    const isRegular = loadType === "regular";
    const isGcash = loadType === "gcash";
    eloadPromoSection.classList.toggle("d-none", !isPromo);
    eloadRegularSection.classList.toggle("d-none", !isRegular);
    eloadGcashSection.classList.toggle("d-none", !isGcash);
    eloadPreviewMode.textContent = isPromo ? "Promo" : isRegular ? "Regular" : "GCash Exclusive";
    eloadPreviewMode.className = `badge rounded-pill px-3 py-2 ${isPromo ? "text-bg-success" : isRegular ? "text-bg-primary" : "text-bg-warning"}`;
  }

  function updatePreview() {
    const formattedNumber = formatPhilippineMobile(eloadMobileNumber.value);
    const loadType = getLoadType();
    const selectedValue = loadType === "promo"
      ? (eloadPromoSelect.value || "Choose an option")
      : loadType === "regular"
        ? (eloadRegularAmount.value ? `Regular ${eloadRegularAmount.value}` : "Enter amount")
        : (eloadGcashSelect.value || "Choose a GCash exclusive option");
    const amount = loadType === "regular" ? Number(eloadRegularAmount.value || 0) : parseLastAmount(selectedValue);

    eloadPreviewNumber.textContent = formattedNumber || "09XX XXX XXXX";
    eloadPreviewNetwork.textContent = selectedNetwork || "Select network";
    eloadPreviewValue.textContent = selectedValue;
    eloadPreviewAmount.textContent = peso.format(amount || 0);
    eloadPreviewTitle.textContent = selectedNetwork ? `${selectedNetwork} request ready` : "Ready to create eload request";
    eloadPreviewSubtitle.textContent = selectedNetwork
      ? `${loadType === "promo" ? "Promo load" : loadType === "regular" ? "Regular load" : "GCash exclusive load"} request is ready for queueing.`
      : "Complete the fields to preview the selected load request.";
    eloadSelectedNetworkText.textContent = selectedNetwork ? `Selected: ${selectedNetwork}` : "No network selected yet";
    eloadNetworkValue.value = selectedNetwork;
    eloadLoadValue.value = selectedValue.includes("Enter amount") ? "" : selectedValue;
    eloadAmountValue.value = String(amount || "");
  }

  function updateGcashPreview() {
    const formattedNumber = formatPhilippineMobile(gcashMobileNumber.value);
    const reference = gcashReferenceNumber.value.trim();
    const amount = Number(gcashAmount.value || 0);
    gcashPreviewNumber.textContent = formattedNumber || "09XX XXX XXXX";
    gcashPreviewReference.textContent = reference || "Pending";
    gcashPreviewFlow.textContent = gcashCashFlow.value;
    gcashPreviewAmount.textContent = peso.format(amount || 0);
    gcashPreviewTitle.textContent = formattedNumber ? "GCash request ready" : "Ready to create GCash request";
    gcashPreviewSubtitle.textContent = formattedNumber || reference || amount
      ? `${gcashCashFlow.value} request is ready for queueing.`
      : "Complete the fields to preview the request details.";
  }

  eloadServiceGrid.addEventListener("click", (event) => {
    const button = event.target.closest("[data-service]");
    if (!button) return;
    selectedService = button.dataset.service;
    updateServiceCards();
  });

  eloadMobileNumber.addEventListener("input", () => {
    eloadMobileNumber.value = formatPhilippineMobile(eloadMobileNumber.value);
    updatePreview();
  });

  gcashMobileNumber.addEventListener("input", () => {
    gcashMobileNumber.value = formatPhilippineMobile(gcashMobileNumber.value);
    updateGcashPreview();
  });

  gcashReferenceNumber.addEventListener("input", updateGcashPreview);
  gcashCashFlow.addEventListener("change", updateGcashPreview);
  gcashAmount.addEventListener("input", updateGcashPreview);

  eloadNetworkGrid.addEventListener("click", (event) => {
    const button = event.target.closest("[data-network]");
    if (!button) return;
    selectedNetwork = button.dataset.network;
    renderNetworks();
    renderPromoOptions();
    updatePreview();
  });

  loadTypeInputs.forEach((input) => {
    input.addEventListener("change", () => {
      updateLoadSections();
      updatePreview();
    });
  });

  eloadPromoSelect.addEventListener("change", updatePreview);
  eloadRegularAmount.addEventListener("input", updatePreview);
  eloadGcashSelect.addEventListener("change", updatePreview);
  eloadAddToCartButton.addEventListener("click", addEloadDraftToCart);
  document.querySelectorAll(".pending-request-copy").forEach((button) => {
    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(button.dataset.copyNumber || "");
        showPendingRequestActionAlert("success", "Mobile number copied.");
      } catch (error) {
        showPendingRequestActionAlert("danger", "Failed to copy mobile number.");
      }
    });
  });

  updateServiceCards();
  renderNetworks();
  renderPromoOptions();
  updateLoadSections();
  updatePreview();
  updateGcashPreview();
</script>
</body>
</html>
