<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="row g-4 mb-4">
        <div class="col-md-4"><div class="metric-card p-4"><div class="mini-note">Total Revenue</div><div class="h2 fw-bold"><%= formatCurrency(reports.totalRevenue) %></div><div class="mini-note">Across all sales</div></div></div>
        <div class="col-md-4"><div class="metric-card p-4"><div class="mini-note">Avg. Daily Sales</div><div class="h2 fw-bold"><%= formatCurrency(reports.averageDaily) %></div><div class="mini-note">Last 7 days</div></div></div>
        <div class="col-md-4"><div class="metric-card p-4"><div class="mini-note">Best Category</div><div class="h2 fw-bold fs-4"><%= reports.bestCategory ? reports.bestCategory.category : 'N/A' %></div><div class="mini-note"><%= reports.bestCategory ? formatCurrency(reports.bestCategory.revenue) : '' %></div></div></div>
      </div>
      <div class="row g-4 mb-4">
        <div class="col-xl-6"><div class="content-card p-4"><div class="section-title mb-3">Weekly Sales Performance</div><canvas id="weeklyChart" height="180"></canvas></div></div>
        <div class="col-xl-6"><div class="content-card p-4"><div class="section-title mb-3">Monthly Sales Trend</div><canvas id="monthlyChart" height="180"></canvas></div></div>
      </div>
      <div class="row g-4">
        <div class="col-xl-6"><div class="content-card p-4"><div class="section-title mb-3">Sales by Category</div><canvas id="categoryPie" height="220"></canvas></div></div>
        <div class="col-xl-6">
          <div class="content-card p-4">
            <div class="section-title mb-3">Category Revenue Breakdown</div>
            <% const totalBreakdown = reports.categoryBreakdown.reduce((sum, item) => sum + item.revenue, 0); %>
            <div class="vstack gap-4">
              <% reports.categoryBreakdown.forEach((item, index) => { %>
                <% const percentage = totalBreakdown ? ((item.revenue / totalBreakdown) * 100).toFixed(1) : 0; %>
                <div>
                  <div class="d-flex justify-content-between"><div class="fw-semibold"><%= item.category %></div><div><%= formatCurrency(item.revenue) %></div></div>
                  <div class="progress progress-soft mt-2"><div class="progress-bar" role="progressbar" style="width: <%= percentage %>%; background-color: <%= ['#10b981', '#0d9488', '#06b6d4', '#3b82f6', '#6366f1', '#8b5cf6'][index % 6] %>"></div></div>
                  <div class="mini-note mt-1"><%= percentage %>% of total sales</div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const weekly = <%- JSON.stringify(reports.weeklySeries) %>;
  const monthly = <%- JSON.stringify(reports.monthlySeries) %>;
  const categories = <%- JSON.stringify(reports.categoryBreakdown) %>;
  const colors = ["#10b981", "#0d9488", "#06b6d4", "#3b82f6", "#6366f1", "#8b5cf6"];
  new Chart(document.getElementById("weeklyChart"), { type: "bar", data: { labels: weekly.map(x => x.label), datasets: [{ data: weekly.map(x => x.total), backgroundColor: "#10b981", borderRadius: 10 }] }, options: { plugins: { legend: { display: false } } } });
  new Chart(document.getElementById("monthlyChart"), { type: "line", data: { labels: monthly.map(x => x.label), datasets: [{ data: monthly.map(x => x.total), borderColor: "#0d9488", pointBackgroundColor: "#0d9488", tension: 0.35 }] }, options: { plugins: { legend: { display: false } } } });
  new Chart(document.getElementById("categoryPie"), { type: "pie", data: { labels: categories.map(x => x.category), datasets: [{ data: categories.map(x => x.revenue), backgroundColor: colors }] } });
</script>
</body>
</html>
